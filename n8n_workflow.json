      "parameters": {
        "jsCode": "const trigger = $('Telegram Trigger').first().json;\nconst msg = trigger.message || {};\nconst chatId = String(msg.chat?.id ?? '');\nconst line = String(msg.text || msg.caption || '').replace(/^\\s*\\/telemost_name\\s*/i, '').trim();\nif (!line) {\n  return [\n    {\n      json: {\n        chat_id: chatId,\n        error:\n          'Укажите имя после команды, например: /telemost_name EN Recording bot\\nСброс к .env: /telemost_name --reset',\n      },\n    },\n  ];\n}\nconst esc = (s) =>\n  String(s)\n    .replace(/\\\\/g, '\\\\\\\\')\n    .replace(/\"/g, '\\\\\"')\n    .replace(/\\$/g, '\\\\$')\n    .replace(/`/g, '\\\\`');\nconst command = '/opt/telemost-recorder/set_recorder_display_name.sh \"' + esc(line) + '\"';\nreturn [{ json: { chat_id: chatId, command } }];"
      },

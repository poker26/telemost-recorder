        "jsCode": "const text = $input.first().json.message?.text || '';\nconst rest = text.replace(/^\\/meeting_join\\s*/i, '').trim();\nconst urlMatch = rest.match(/https?:\\/\\/[^\\s]+/);\nconst esc = (s) => String(s).replace(/\"/g, '\\\\\"');\nconst chatId = String($input.first().json.message.chat.id);\nif (!urlMatch) {\n  return [{ json: { command: `echo '{\"error\":\"Укажите ссылку Телемоста в том же сообщении после /meeting_join\"}'` } }];\n}\nconst joinUrl = urlMatch[0];\nconst titlePart = rest.replace(joinUrl, '').trim() || ('Встреча ' + new Date().toLocaleString('ru-RU', { timeZone: 'Europe/Moscow' }));\nconst command = '/opt/telemost-recorder/run_join.sh \"' + esc(joinUrl) + '\" \"' + esc(titlePart) + '\" \"' + esc(chatId) + '\"';\nreturn [{ json: { command } }];"
